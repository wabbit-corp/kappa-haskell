-- Stress test: user-defined operator fixity declarations are accepted
-- Spec: lexical.operator_identifiers_fixity.declarations

--! mode check

-- Declare right-associative operator at precedence 5.
infixr 5 (@@)

(@@) : Int -> Int -> Int
let (@@) x y = x + y * 2

-- POSITIVE: right-associativity means 1 @@ 2 @@ 3 parses as 1 @@ (2 @@ 3).
let test : Int = 1 @@ 2 @@ 3

-- Declare left-associative operator at precedence 6.
infixl 6 (##)

(##) : Int -> Int -> Int
let (##) x y = x * 3 + y

-- POSITIVE: left-associativity: 1 ## 2 ## 3 parses as (1 ## 2) ## 3.
let test2 : Int = 1 ## 2 ## 3

--! assertNoErrors
