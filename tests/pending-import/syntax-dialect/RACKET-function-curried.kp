-- Source: Racket guide define.scrbl (curried function shorthand)
-- Source docs: racket guide define.scrbl (corpus repos/github-racket-racket/docs/pkgs/racket-doc/scribblings/guide/define.scrbl; restored 2026-06-11 from RACKET_CANDIDATE_LEDGER.md)
-- Spec: expressions.lambdas, declarations.terms
--
-- A function may be curried: it takes one argument and returns a function
-- that takes the next. Kappa functions are naturally curried — `f x y` is
-- sugar for `(f x) y`. Partial application creates a new function value.

--! mode check

-- POSITIVE: two-argument function is naturally curried.
add : Int -> Int -> Int
let add x y = x + y

-- POSITIVE: partial application — apply to one argument to get a unary function.
addFive : Int -> Int
let addFive = add 5

-- POSITIVE: section-style: a function that adds a fixed value.
addOffset : Int -> Int -> Int
let addOffset offset = \n -> n + offset

-- POSITIVE: curried map: first supply the function, then the list.
mapInt : (Int -> Int) -> List Int -> List Int
let mapInt _ []       = []
let mapInt f (h :: t) = f h :: mapInt f t

incrementAll : List Int -> List Int
let incrementAll = mapInt (\x -> x + 1)

-- POSITIVE: compose two functions by partial application.
compose : (B -> C) -> (A -> B) -> A -> C
let compose g f x = g (f x)

double : Int -> Int
let double = \x -> x + x

-- POSITIVE: curried function used inline without naming the partial application.
tripled : List Int
let tripled = mapInt (\x -> x * 3) [1, 2, 3, 4]

-- NEGATIVE: applying a two-argument function to three arguments is a type error.
badArity : Int
let badArity = add 1 2 3    --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch
