-- Source artifacts: synquid test/unit/HigherOrder.sq, test/current/Evaluator.sq —
--                 `qualifier {_v > 0, _v >= 0}` and `qualifier {x <= y,
--                 x != y}` declare proof-hint qualifiers used during
--                 Synquid's predicate-abstraction-driven synthesis.
--                 Kappa has no analog: `qualifier` is a Synquid synthesizer-
--                 specific surface (see SYNQUID_SPEC_ADDITIONS.md,
--                 SA-SYNQUID-03).
-- Spec: compiler.frontir.standard_diagnostic_families.name_import
--       (kappa.name.unresolved)
--
-- Kappa has no portable "qualifier hint" surface. This fixture pins down
-- the portable shape: an ordinary recursive comparison does NOT need a
-- declared qualifier list, and an attempt to call a `qualifier`-style
-- identifier as if it were a real declaration is rejected by ordinary
-- name resolution.

--! mode check

data PNat : Type =
    Z
    S PNat

-- POSITIVE: ordinary recursive comparison, no qualifier hint needed.
ltz : PNat -> PNat -> Bool
let ltz m n =
    match m
      case Z      ->
          match n
            case Z     -> False
            case (S _) -> True
      case (S m') ->
          match n
            case Z      -> False
            case (S n') -> ltz m' n'

-- POSITIVE: ordinary use of ltz; result type is Bool.
checkLtz : Bool
let checkLtz = ltz Z (S Z)

-- NEGATIVE: referring to an unknown `qualifier`-style identifier as if
-- it were a real declaration is a name-resolution failure (qualifier is
-- not a known Kappa declaration form).
badRef : Bool
let badRef = qualifier (S Z)                    --!! kappa.name.unresolved

--! assertDiagnosticFamily error kappa.name.unresolved
