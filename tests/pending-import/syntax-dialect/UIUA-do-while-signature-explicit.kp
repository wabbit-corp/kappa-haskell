-- Source issue: Uiua #293 ("do modifier: Function signature match" — the
--   `do` modifier's body has elaborated signature |1.3 but the user
--   declared |1.1 and the compiler accepts neither annotation cleanly).
-- Spec: declarations.signatures, expressions.application,
--       compiler.frontir.standard_diagnostic_families.type_equality.
--
-- A function whose body uses a looping combinator must still have its
-- declared signature checked against the elaborated arity of the loop
-- body. The defining-site mismatch must be diagnosed, not deferred to
-- the call site.

module test

--! mode check

-- POSITIVE: a do-while-style step function with a matching signature.
collatzStep : Int -> Int
let collatzStep x =
    if x % 2 == 0
        then x / 2
        else 3 * x + 1

iterCollatz : Int -> Int
let iterCollatz n =
    if n <= 1
        then n
        else iterCollatz (collatzStep n)

--! assertType iterCollatz Int -> Int

-- NEGATIVE: declared signature `Int -> Int` but the body returns a
-- triple (mirrors Uiua's "declared |1.1 but inferred |1.3"); must be
-- diagnosed at the defining site as a type mismatch.
badLoop : Int -> Int
let badLoop n = (n, n + 1, n * 2)               --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch
