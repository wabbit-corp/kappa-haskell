-- Source issues: lamdu#192 — stack size exceeded error in simple snippet;
--   tests/programs/recursive-func.json, fold.json. Lamdu supports direct
--   recursion through let-rec / def-rec; recursive definitions must
--   type-check and accept self-reference in their body.
-- Spec: declarations.totality.local_recursion_examples,
--       declarations.totality.recursive_group_elaboration_invariance
--   §13.x: a recursive let-binding may reference its own name in its
--   body; recursion requires totality justification at well-typedness
--   level for the type system, even when termination is not checked.
--
-- Recursive functions must be permitted in let-bindings and at the
-- top level. Reference cycles must be checked through the type
-- system, not silently accepted.

--! mode check

-- POSITIVE: simple top-level recursion (factorial).
factorial : Nat -> Nat
let factorial n =
    if n == 0 then 1 else n * factorial (n - 1)

useFact : Nat
let useFact = factorial 5

-- POSITIVE: recursive function with multiple parameters.
gcd : Nat -> Nat -> Nat
let gcd a b =
    if b == 0 then a else gcd b (a mod b)

useGcd : Nat
let useGcd = gcd 48 18

-- POSITIVE: structural recursion over a parameterized nominal.
data List (a : Type) : Type =
    Nil
    Cons a (List a)

length : forall (a : Type). List a -> Nat
let length xs =
    match xs
    case Nil          -> 0
    case Cons _ rest  -> 1 + length rest

useLen : Nat
let useLen = length (Cons 1 (Cons 2 (Cons 3 Nil)))

-- POSITIVE: recursive function over a sum/variant value.
data Tree (a : Type) : Type =
    Leaf
    Node (left : Tree a) (value : a) (right : Tree a)

count : forall (a : Type). Tree a -> Nat
let count t =
    match t
    case Leaf              -> 0
    case Node l _ r        -> 1 + count l + count r

-- POSITIVE: recursive let-binding inside a function body.
sumDown : Nat -> Nat
let sumDown start =
    let go : Nat -> Nat
        go n = if n == 0 then 0 else n + go (n - 1)
    go start

-- NEGATIVE: a recursive definition whose body has the wrong type.
badRec : Nat -> Nat
let badRec n = badRec    --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch
