-- Source issues: FLIX-4024, FLIX-4027
-- Spec: compiler.frontir.standard_diagnostic_families.pattern_exhaustiveness_reachability
-- Exhaustiveness checking must apply recursively throughout an expression:
-- a non-exhaustive match that appears as a sub-expression (e.g., as the
-- scrutinee of an outer match, or inside a function body) must still be
-- flagged. The compiler must not miss inner matches just because an outer
-- match is exhaustive.

--! mode check

data MyList (a : Type) : Type =
    Nil
    Cons a (MyList a)

-- NEGATIVE TEST: the inner match is non-exhaustive (only `Cons` is matched).
-- It appears as the scrutinee of an outer match; must still be rejected.
let bad_inner (xs : MyList Int) : String =
    match
        (match xs
         case Cons _ _ -> Nil)  -- `Nil` branch missing in inner match --!! kappa.pattern.non-exhaustive
    case Nil -> "nil"
    case Cons _ _ -> "cons"

-- NEGATIVE TEST: non-exhaustive match in a let-binding position.
let bad_let (xs : MyList Int) : String =
    let first =
        match xs
        case Cons x _ -> x   -- `Nil` branch missing --!! kappa.pattern.non-exhaustive
    show first

-- POSITIVE TEST: both nested matches are exhaustive.
let good_nested (xs : MyList Int) : Int =
    match
        (match xs
         case Nil     -> 0
         case Cons x _ -> x)
    case 0 -> -1
    case n -> n

-- POSITIVE TEST: recursive function with exhaustive match at every level.
let sum_list (xs : MyList Int) : Int =
    match xs
    case Nil        -> 0
    case Cons x rest -> x + sum_list rest

-- expect: bad_inner and bad_let rejected with non-exhaustive error;
--         good_nested, sum_list accepted
