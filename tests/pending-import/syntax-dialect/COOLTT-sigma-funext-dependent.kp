-- Source artifacts: cooltt test path-types.cooltt (funextdep: dependent funext,
--               pairext: eta for sigma), test prelude.cooltt (funext, cong).
-- Source tests: cooltt test/path-types.cooltt (corpus repos/github-redprl-cooltt/tests/test/path-types.cooltt; restored 2026-06-11 from COOLTT_ISSUE_IMPORT_PLAN.md)
-- Spec: types.propositions.propositional_equality_type_positions
--
-- Dependent function extensionality (depfunext):
-- If two dependent functions `f g : forall (x : A) -> B x` agree on all inputs
-- (there exists `h : forall (x : A) -> f x = g x`), then `f = g`.
-- This is often taken as an axiom in MLTT but is provable in cubical type theory.
-- In Kappa, it is a primitive or axiom; the spec must state whether it holds.

--! mode check

-- POSITIVE: non-dependent function extensionality.
funext : forall {A B : Type} {f g : A -> B} ->
         (forall (x : A) -> f x = g x) ->
         f = g
let funext h = ?funextAxiom    --!! kappa.hole.unsolved

-- POSITIVE: dependent function extensionality.
depFunext :
    forall {A : Type} {B : A -> Type}
    {f g : forall (x : A) -> B x} ->
    (forall (x : A) -> f x = g x) ->
    f = g
let depFunext h = ?depFunextAxiom    --!! kappa.hole.unsolved

-- POSITIVE: pair extensionality (eta for sigma).
-- Two pairs are equal if their first and second components are equal.
pairExt :
    forall {A : Type} {B : A -> Type}
    (p q : (x : A, B x)) ->
    (h1 : p.1 = q.1) ->
    (h2 : transport B h1 p.2 = q.2) ->
    p = q
let pairExt _ _ refl refl = refl

-- POSITIVE: `ap` (congruence) for dependent functions.
apDep :
    forall {A : Type} {B : A -> Type}
    (f : forall (x : A) -> B x) {a b : A} (p : a = b) ->
    transport B p (f a) = f b
let apDep _ refl = refl

-- POSITIVE: composition of paths in a family.
-- transport is functorial: transport (p ∘ q) = transport q ∘ transport p.
transportComp :
    forall {A : Type} (P : A -> Type) {a b c : A} (p : a = b) (q : b = c) ->
    transport P (trans p q) = (\x -> transport P q (transport P p x))
let transportComp _ refl refl = refl

-- POSITIVE: a higher-order function accepting a dependent path obligation.
useDepFunext :
    forall {A : Type} {B : A -> Type}
    (f g : forall (x : A) -> B x) ->
    (forall (x : A) -> f x = g x) ->
    Nat
let useDepFunext f g h = zero    -- just checking the type is well-formed

-- NEGATIVE: applying funext to something that is not a pointwise equality proof.
badFunext : forall {A B : Type} {f g : A -> B} ->
            Nat -> f = g
let badFunext n = funext n    --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.hole.unsolved
--! assertDiagnosticFamily error kappa.type.mismatch
