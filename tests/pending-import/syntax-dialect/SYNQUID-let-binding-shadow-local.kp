-- Source artifacts: synquid test/checking/List-Replicate.sq —
--                 `replicate = \n . \x . let n' = n - 1 in ...` introduces a
--                 local binder shadowed only by the local scope.
--                 test/unit/HOChecking.sq tests deeper closure forms.
-- Spec: declarations.let_in,
--       expressions.lambdas
--
-- A `let` inside a body introduces a local binding whose scope is the
-- body of the let. The Kappa-portable obligation is that the local binder
-- shadows an outer binding of the same name lexically, that the body
-- resolves the name to the most-recent binding, and that the outer
-- binding is restored outside the let.

--! mode check

data PNat : Type =
    Z
    S PNat

data List (a : Type) : Type =
    Nil
    Cons (head : a) (tail : List a)

-- POSITIVE: a function where a local let shadows a parameter name.
useLocal : PNat -> PNat
let useLocal n =
    let n : PNat = S n in   -- shadows the parameter `n` locally
    n

-- POSITIVE: a function where a let-bound name is restored outside its
-- let body.
nestedLet : PNat -> PNat
let nestedLet n =
    let f : PNat -> PNat = \ x -> S x in
    let n : PNat         = f n in
    n

-- POSITIVE: shadowing inside a match arm; the binder is only visible
-- inside the arm body.
matchShadow : List PNat -> PNat
let matchShadow xs =
    match xs
      case Nil          -> Z
      case (Cons x ys)  ->
          let x : PNat = S x in    -- shadows the binder from the arm
          x

-- NEGATIVE: a let-bound name escaping its own RHS is unresolved when
-- referenced outside the surrounding `let ... in body` expression.
badEscape : PNat
let badEscape =
    let inside : PNat = S Z in inside
    -- `inside` is out of scope below; the surrounding `let ... in ...`
    -- body ended at the previous line.
    inside                                       --!! kappa.name.unresolved

--! assertDiagnosticFamily error kappa.name.unresolved
