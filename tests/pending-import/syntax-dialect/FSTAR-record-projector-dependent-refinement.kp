-- Source issue: FSTAR-1276
-- Spec: types.records.values
-- A record projector for a field whose type mentions an earlier field
-- must typecheck: the projected value must satisfy the refinement that
-- refers to the co-projected earlier field.

--! mode check

-- A record type where the second field's type depends on the first.
type Container = (pred : Nat -> Type0, value : Nat)

get_value : Container -> Nat
let get_value c = c.value

-- A more constrained record: second field type is a refinement involving the first.
type SizedVec (A : Type0) = (size : Nat, vec : { n : Nat | n = size })

-- Projecting `vec` must yield a value whose type mentions `size` from the record.
get_vec_len : {A : Type0} -> (sv : SizedVec A) -> { n : Nat | n = sv.size }
let get_vec_len sv = sv.vec

--! assertNoErrors
