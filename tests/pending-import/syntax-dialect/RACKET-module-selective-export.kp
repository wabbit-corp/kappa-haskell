-- Source: Racket guide module-provide.scrbl (provide with selective lists)
-- Source docs: racket guide module-provide.scrbl (corpus repos/github-racket-racket/docs/pkgs/racket-doc/scribblings/guide/module-provide.scrbl; restored 2026-06-11 from RACKET_CANDIDATE_LEDGER.md)
-- Spec: modules.exports, modules.visibility_opacity_private_opaque,
--       compiler.frontir.standard_diagnostic_families.name_import
--
-- A module may selectively export only certain names. Names not included in
-- the export list are not accessible from outside the module. Accessing an
-- unexported name from outside the module is an kappa.name.unresolved error.

--! mode check

module math

-- Public exports (explicitly exported)
public add : Int -> Int -> Int
let add x y = x + y

public multiply : Int -> Int -> Int
let multiply x y = x * y

-- Private helper — not part of the module's export surface
private double : Int -> Int
let double x = x * 2

-- Private constant
private defaultScale : Int
let defaultScale = 10

-- Public function that uses private helpers internally
public scale : Int -> Int
let scale x = multiply x defaultScale

module client
import math.(add, scale)

-- POSITIVE: add and scale are exported and in scope.
result1 : Int
let result1 = add 3 4

result2 : Int
let result2 = scale 5

-- POSITIVE: qualified access through module alias also works.
module clientQual
import math as m

qualResult : Int
let qualResult = m.add 10 20

-- NEGATIVE: multiply was not imported; it is not in scope.
badMultiply : Int
let badMultiply = multiply 3 3    --!! kappa.name.unresolved

-- NEGATIVE: double is private and cannot be accessed from outside math.
badDouble : Int
let badDouble = math.double 7     --!! kappa.name.unresolved

-- NEGATIVE: defaultScale is private and not part of math's export surface.
badScale : Int
let badScale = math.defaultScale  --!! kappa.name.unresolved

--! assertDiagnosticFamily error kappa.name.unresolved
