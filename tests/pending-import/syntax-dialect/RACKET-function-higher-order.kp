-- Source: Racket guide apply.scrbl (higher-order functions)
-- Source docs: racket guide apply.scrbl (corpus repos/github-racket-racket/docs/pkgs/racket-doc/scribblings/guide/apply.scrbl; restored 2026-06-11 from RACKET_CANDIDATE_LEDGER.md)
-- Spec: types.functions, expressions.application
--
-- Higher-order functions take functions as arguments or return functions as
-- values. The type of such a function carries the type of the callback.
-- Passing a callback with a mismatched type is a type mismatch.

--! mode check

-- POSITIVE: map applies a function to each element of a list.
map : (A B : Type) -> (A -> B) -> List A -> List B
let map _ _ _ []       = []
let map A B f (h :: t) = f h :: map A B f t

-- POSITIVE: filter retains elements for which the predicate holds.
filter : (A : Type) -> (A -> Bool) -> List A -> List A
let filter _ _ []       = []
let filter A p (h :: t) =
    if p h
    then h :: filter A p t
    else filter A p t

-- POSITIVE: fold reduces a list with a binary function.
foldLeft : (B : Type) -> (A : Type) -> (B -> A -> B) -> B -> List A -> B
let foldLeft _ _ _ acc []       = acc
let foldLeft B A f acc (h :: t) = foldLeft B A f (f acc h) t

-- POSITIVE: compose two functions.
compose : (B -> C) -> (A -> B) -> A -> C
let compose g f x = g (f x)

-- POSITIVE: apply a list of functions to a single value.
applyAll : (A : Type) -> List (A -> A) -> A -> A
let applyAll _ []       x = x
let applyAll A (f :: fs) x = applyAll A fs (f x)

-- POSITIVE: flip argument order of a two-argument function.
flip : (A -> B -> C) -> B -> A -> C
let flip f b a = f a b

-- NEGATIVE: callback type mismatch — map expects A -> B but gets A -> A -> B.
badMap : List Int
let badMap = map Int Int (add) [1, 2, 3]   --!! kappa.type.mismatch

add : Int -> Int -> Int
let add x y = x + y

-- NEGATIVE: passing a non-function as the callback.
badFilter : List Int
let badFilter = filter Int 42 [1, 2, 3]   --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch
