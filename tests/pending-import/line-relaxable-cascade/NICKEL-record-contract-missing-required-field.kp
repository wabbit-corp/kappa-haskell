-- Source issues: nickel #480, #517, #900, #1239, contracts.md
-- Spec: types.records.formation, compiler.frontir.standard_diagnostic_families.type_equality
-- A closed record contract declares which fields are required. When a value does not
-- provide all required fields, the contract must fail with kappa.type.mismatch.
-- The diagnostic must identify:
--   * which specific field is missing (payload: field name),
--   * the record that was supposed to provide the field (origin),
--   * the contract that required the field (obligation-introduced-here).
-- The diagnostic must NOT blame a neighboring field or the entire record type
-- without identifying the specific missing field.

module test

-- A record contract requiring three fields.
type ServerConfig = (host : String, port : Number, tls : Bool)

-- NEGATIVE: missing `port` — the diagnostic must name `port` as the missing field.
missingPort : ServerConfig
let missingPort = (host = "localhost", tls = True)     --!! kappa.type.mismatch

--! mode check
--! assertDiagnosticFamily error kappa.type.mismatch

-- NEGATIVE: missing `tls` — a different missing field, same contract.
missingTls : ServerConfig
let missingTls = (host = "example.com", port = 443)    --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch

-- NEGATIVE: empty record — all fields missing.
allMissing : ServerConfig
let allMissing = ()                                    --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch

-- POSITIVE: all required fields present.
fullConfig : ServerConfig
let fullConfig = (host = "api.example.com", port = 8443, tls = True)


-- NEGATIVE: deeply nested missing field — must blame the nested field, not the top level.
type DbConfig = (primary : ServerConfig, replica : ServerConfig)

missingReplicaPort : DbConfig
let missingReplicaPort = (
    primary = (host = "db1", port = 5432, tls = False),
    replica = (host = "db2", tls = True)               --!! kappa.type.mismatch
)

--! assertDiagnosticFamily error kappa.type.mismatch

-- POSITIVE: both nested records complete.
fullDbConfig : DbConfig
let fullDbConfig = (
    primary = (host = "db1", port = 5432, tls = False),
    replica = (host = "db2", port = 5433, tls = True)
)

