-- Source: granule-project/granule PR #290 (Improving solving equations
--         on universally quantified semirings)
-- Spec: types.universes.quantities.solver_summary,
--       types.universes.quantities.reified_quantity_satisfaction,
--       compiler.frontir.standard_diagnostic_families.quantity_ownership
-- The quantity solver must decide obligations like `r + 1 ⊑ s` over
-- abstract quantity elements (GSA-07). A closed but false obligation
-- surfaces `kappa.quantity.unsatisfied`; an unsolvable symbolic
-- obligation surfaces `kappa.quantity.satisfies`.

module test

--! mode check

-- POSITIVE: closed obligation 2 + 1 ⊑ 3 is decidable.
addClosed : forall (a : Type). (3 x : a) -> (a, a, a)
let addClosed x = (x, x, x)


-- POSITIVE: symbolic obligation discharged via an explicit premise.
addSym : forall (r : Quantity) (a : Type).
    QuantitySatisfies (r + 1) 2 => (r x : a) -> (a, a)
let addSym x = (x, x)


-- NEGATIVE: closed obligation 1 + 1 ⊑ 1 is false; must be rejected.
addClosedBad : forall (a : Type). (1 x : a) -> (a, a)
let addClosedBad x = (x, x)   --!! kappa.quantity.unsatisfied

--! assertDiagnosticFamily error kappa.quantity.unsatisfied

-- NEGATIVE: symbolic obligation that the solver cannot discharge without
-- a premise.
addSymBad : forall (r : Quantity) (a : Type). (r x : a) -> (a, a, a)
let addSymBad x = (x, x, x)   --!! kappa.quantity.satisfies

--! assertDiagnosticFamily error kappa.quantity.satisfies
