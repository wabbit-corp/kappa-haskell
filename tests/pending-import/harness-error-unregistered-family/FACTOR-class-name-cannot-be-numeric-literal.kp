-- Source issue: Factor #183 (`SINGLETON: 3` should be rejected; the
--   parser allowed a class name that is a numeric literal, breaking
--   ordinary identifier rules and confusing arithmetic dispatch).
-- Spec: lexical.identifiers, data_types.data_declarations,
--       compiler.frontir.portable_diagnostic_code_aliases
--       (E_RECOVERY_SKIPPED_INVALID_SYNTAX or E_QUOTE_MALFORMED_SYNTAX),
--       compiler.frontir.standard_diagnostic_families.macro_elaboration
--       (family kappa.syntax.quotation).
--
-- A data or type declaration whose name token is a numeric literal must
-- be rejected by the parser. The diagnostic must be a parse-time
-- syntax error, not a downstream name-resolution failure, so tooling
-- can surface a useful repair.

module test

--! mode check

-- POSITIVE: a normal identifier is accepted as a data name.
data Three : Type =
    Three

okThree : Three
let okThree = Three

-- NEGATIVE: numeric-literal token in declaration-name position is
-- rejected by the parser. The exact diagnostic family depends on
-- recovery, but the harness asserts that some parse/recovery error is
-- present and that the rest of the file's name resolution still works
-- via recovery.
data 3 : Type =                           --!! E_RECOVERY_SKIPPED_INVALID_SYNTAX
    Tag

--! assertDiagnostic error E_RECOVERY_SKIPPED_INVALID_SYNTAX
