-- Source artifacts: synquid corpus uses subset refinement types ubiquitously:
--                 `type Nat = {Int | _v >= 0}`, `type Pos = {Int | _v > 0}`,
--                 `type Phase = {Int | 0 <= _v && _v < 4}`,
--                 `BST {a | _v < x}`, `IList {a | x < _v}`, ... These
--                 first-class subset types are not specified in Kappa
--                 (see SYNQUID_SPEC_ADDITIONS.md, SA-SYNQUID-01).
-- Spec: types.propositions.propositional_equality_type_positions,
--       expressions.match.constructor_branches_introduce_explicit_refinement_evidence,
--       data_types.gadts
--
-- This fixture exercises the Kappa-portable substitute: an indexed
-- encoding plus pattern-introduced evidence from constructor matches.
-- Where Synquid writes `{Int | _v >= 0}` Kappa requires an indexed
-- encoding (or an erased propositional witness).

--! mode check

data PNat : Type =
    Z
    S PNat

-- POSITIVE: an indexed encoding of "non-negative" that maps onto
-- Synquid's `{Int | _v >= 0}`. The constructor evidence guarantees
-- non-negativity at every introduction site (PNat is the index).
data NonNeg : Type =
    Zero  : NonNeg
    Pos   : (n : PNat) -> NonNeg

-- POSITIVE: a function that produces NonNeg without requiring a
-- propositional subset type.
absP : PNat -> NonNeg
let absP n =
    match n
      case Z      -> Zero
      case (S k)  -> Pos (S k)

-- POSITIVE: pattern matching on NonNeg introduces evidence that the
-- value is non-negative; the extraction is total.
toPNat : NonNeg -> PNat
let toPNat v =
    match v
      case Zero    -> Z
      case (Pos n) -> n

-- POSITIVE: composing NonNeg values via match preserves the invariant.
inc : NonNeg -> PNat
let inc v =
    match v
      case Zero    -> S Z
      case (Pos n) -> S n

-- NEGATIVE: applying `inc` to a PNat (not a NonNeg) is a type mismatch.
-- This pins down that NonNeg is a distinct nominal type, not a refined
-- alias of PNat.
badArg : PNat
let badArg = inc Z                              --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch
