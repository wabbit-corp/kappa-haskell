-- Source issues: odin#5292 (missing errors when accepting proc parameters which
--               use parapoly when they don't ask for parapoly),
--               odin#4045 (disabled polymorphic procedure error for different parameter types)
-- Spec: compiler.frontir.standard_diagnostic_families.type_equality (kappa.type.mismatch),
--       types.quantification
-- A function value of the wrong type must be rejected when passed to a
-- higher-order function slot. In particular, passing a function whose argument
-- or return type differs from the expected signature must emit kappa.type.mismatch.
--
-- NOTE (spec gap): the original Odin obligation ("polymorphic function is not
-- coercible to a monomorphic slot") is not straightforwardly portable to Kappa,
-- because Kappa's implicit-argument resolution may automatically instantiate a
-- polymorphic function at the call site. The portable obligation tested here is
-- the general function-type mismatch: wrong argument or return type.

--! mode check

-- A monomorphic function slot.
let applyToTen (f : Int -> Int) : Int = f 10

-- POSITIVE: a monomorphic Int -> Int function is passed — accepted.
let double (x : Int) : Int = x * 2

let okApply : Int = applyToTen double


-- NEGATIVE: wrong return type — Int -> String does not satisfy Int -> Int.
let returnStr (x : Int) : String = ""

let badApplyWrongReturn : Int =
    applyToTen returnStr    --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch

-- A higher-order function that takes a String -> String function.
let withStringFn (f : String -> String) : String = f "hello"

let appendBang (s : String) : String = s ++ "!"

-- POSITIVE: monomorphic String -> String function.
let okWithString : String = withStringFn appendBang


-- NEGATIVE: wrong-typed monomorphic function (Int -> Int ≠ String -> String).
let badWithWrongMono : String =
    withStringFn double    --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch

-- NEGATIVE: wrong argument type (Int -> Int passed where String -> Int expected).
let applyToStr2 (f : String -> Int) : Int = 0

let badArgType : Int =
    applyToStr2 double    --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch
