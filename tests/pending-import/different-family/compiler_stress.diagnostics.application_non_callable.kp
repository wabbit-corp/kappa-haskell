-- Stress test: applying a non-callable value produces kappa.type.mismatch
-- Spec: compiler.frontir.standard_diagnostic_families.type_equality

--! mode check

-- notFn is an Int, not a function.
let notFn : Int = 42

-- NEGATIVE: applying an Int as if it were a function.
let bad : Int = notFn 5   --!! kappa.type.mismatch

--! assertDiagnosticFamily error kappa.type.mismatch
