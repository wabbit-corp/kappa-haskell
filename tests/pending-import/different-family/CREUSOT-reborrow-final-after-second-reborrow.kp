-- Source issues: CREUSOT-final_borrows
-- Source issues: creusot-rs/creusot#668, #824; harvested tests/should_fail/final_borrows.rs (restored 2026-06-11 from CREUSOT_CANDIDATE_LEDGER.md)
-- Spec: types.universes.borrow_lifetimes_escape_prevention,
--       types.universes.disjoint_path_borrowing_records,
--       compiler.frontir.standard_diagnostic_families.borrow_capture_region,
--       compiler.diagnostics.path_sensitive_diagnostics.overlapping_borrow_or_update_footprints
-- Family: kappa.borrow.overlap (Kappa §3.2.7 / §3.3)
-- "Final borrow" semantics: holding two reborrows `b1` and `b2` of the
-- same path live simultaneously is overlapping mutable footprints; the
-- second reborrow invalidates the prophecy of the first.  Pending spec
-- gap CREUSOT-SA-12 covers reborrow obligations.

module test

--! mode check

-- NEGATIVE: holding `b1` and `b2` both alive across the use of `bor`
-- creates overlapping mutable footprints on the same path *bor.
twoReborrowsOverlap : (inout bor : Int) -> Unit
let twoReborrowsOverlap bor =
    let b1 = &mut *bor in
    let b2 = &mut *bor in            --!! kappa.borrow.overlap
    b1 := !b1 + !b2

-- NEGATIVE: assigning through *bor while `b1` is still considered live
-- changes the prophecy of `b1` (it is no longer the "final" reborrow);
-- using `b1` afterwards must be rejected as an overlap with the write
-- to *bor.
storeChangesProphecy : (inout bor : Int) -> Unit
let storeChangesProphecy bor =
    let b1 = &mut *bor in
    bor := !bor + 1                  --!! kappa.borrow.overlap
    ; b1 := !b1 + 1

--! assertDiagnosticFamily error kappa.borrow.overlap
