-- Source issue: Kitten #117 (finish module system; `import foo (bar)`
--   imports only `bar` from `foo`).
-- Spec: modules.imports, modules.imports.item_kind_selectors,
--       compiler.frontir.standard_diagnostic_families.name_import
--       (family kappa.name.unresolved).
--
-- A selective import brings only the listed names into scope; other
-- exports of the imported module are not visible without qualification.

module consumer

import provider.(exportedA)

--! mode check

-- POSITIVE: listed import is visible.
useA : Int
let useA = exportedA

-- NEGATIVE: a name not on the import list is not visible bare.
useB : Int
let useB = exportedB                       --!! kappa.name.unresolved

--! assertDiagnosticFamily error kappa.name.unresolved
