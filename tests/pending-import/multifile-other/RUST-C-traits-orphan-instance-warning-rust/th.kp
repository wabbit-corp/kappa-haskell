-- Spec: traits.instances, traits.instances.resolution_algorithm.
-- Defines the trait `Th`. Together with `ty.lang` (defining the type) and
-- `orphan.lang` (defining an instance neither in this module nor in the
-- type's module), this suite exercises the orphan-instance warning.
module th

trait Th (a : Type) =
    thLabel : a -> String
