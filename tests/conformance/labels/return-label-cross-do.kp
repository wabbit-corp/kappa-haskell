--! mode run
--! assertNoErrors
--! assertStdout "before-return\n"

-- §18.5/§18.8.3.1: a nested `do` block in statement position is transparent to
-- abrupt completion. `return@main` written inside `inner@do` (a nested do
-- STATEMENT, not a function/lambda boundary) resolves to the enclosing
-- function `main` and returns from it, so "after" is never printed. (A
-- first-class do VALUE — `let x = do …` — stays opaque; see
-- labels/return-label-in-do-value.kp.)
main : UIO Unit
let main = do
    inner@do
        printlnString "before-return"
        return@main ()
    printlnString "after"
