--! assertNoErrors
--! assertNoWarnings
module main

-- Transparent helper measures are accepted only because the helper normalizes
-- to primitive arithmetic; the helper spelling itself is not trusted.
maxInt : Integer -> Integer -> Integer
let maxInt a b =
    if leInt a b then b else a

countdownViaHelpers : Integer -> Integer
let countdownViaHelpers n decreases maxInt 0 n =
    if leInt n 0 then 0 else countdownViaHelpers (subInt n 1)
