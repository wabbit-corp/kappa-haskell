--! mode check
--! assertNoErrors
--! assertNoWarnings
--! assertType rendered Elab String
--! assertType origin Elab SyntaxOrigin
--! assertType quotedPlusOne Elab (Syntax Integer)
--! assertType value Integer

-- §21.5/§21.9: reflection queries are Elab actions; Elab do blocks
-- bind elaboration-time results before quoting and splicing.
rendered : Elab String
let rendered =
    renderSyntax '{ 1 + 1 }

origin : Elab SyntaxOrigin
let origin =
    syntaxOrigin '{ 1 }

ten : Elab (Syntax Integer)
let ten =
    pure '{ 10 }

quotedPlusOne : Elab (Syntax Integer)
let quotedPlusOne =
    do
        let e <- ten
        pure '{ ${e} + 1 }

value : Integer
let value =
    $(quotedPlusOne)
