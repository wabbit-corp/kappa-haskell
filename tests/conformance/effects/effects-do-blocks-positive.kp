module main

sumList : List Int -> Int
let sumList xs =
    match xs
      case Nil -> 0
      case head :: tail -> head + sumList tail

let main : IO Unit = do
    let nums = 10 :: 20 :: 42 :: Nil
    let total = sumList nums
    printInt total

--! assertNoErrors
--! assertDeclKinds signature, let, let
