module main

-- Hostile-audit RT-3 pin (§18.6): the out-of-loop guard must NOT flag a `break`/`continue` that is
-- lexically enclosed by a loop body — including when nested inside an `if` within the loop. (Runtime
-- control flow for in-loop break/continue remains a separately-tracked gap; this pin asserts only that the
-- new compile-time guard accepts the in-loop forms.)
f : Bool -> UIO Unit
let f (cond : Bool) : UIO Unit =
    do
        while cond do
            if cond then
                break
            else
                continue
        pure ()

--! mode check
--! assertNoErrors
