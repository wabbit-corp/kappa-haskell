--! assertNoErrors
--! assertEval result 20

-- §18.1: a TOP-LEVEL `effect` declaration (not the §9.3.1.1 `scoped effect`
-- local form) declares a module-wide effect interface. Its operations are
-- invoked as `Label.op arg`, it appears in effect rows `<[State : State]>`,
-- and `handle`/`deep handle` resolve its label module-wide. Mirrors
-- effects/deep-handler-state.kp but with the effect declared at module scope.
module main

effect State =
    1 get : Unit -> Int
    1 put : Int -> Unit

comp : Eff <[State : State]> Int
let comp =
    do
        let a <- State.get ()
        let _ <- State.put 5
        let b <- State.get ()
        pure (a + b)

let handled =
    deep handle State comp with
        case return x -> pure x
        case get _ k -> k 10
        case put _ k -> k ()

result : Int
let result = runPure handled
