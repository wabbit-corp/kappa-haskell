module main

-- Source issue: Idris2#764
-- Kappa analogue: a value bound by `do` should remain a valid `match` scrutinee without requiring a redundant local
-- type annotation.
-- Spec: §7.5, §8.2, §14.1.1

main : IO Int
let main = do
    value <- pure 42
    match value
      case n -> pure n

--! assertNoErrors
--! assertType main IO Int
--! assertExecute main 42
