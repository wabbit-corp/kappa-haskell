module main

sumList : List Int -> Int
let sumList xs =
    match xs
    case Nil -> 0
    case head :: tail -> head + sumList tail

result : Int
let result = sumList (10 :: 20 :: 42 :: Nil)

--! assertNoErrors
--! assertType result Int
--! assertDeclKinds signature, let, signature, let
