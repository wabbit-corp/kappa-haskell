module main

import std.prelude.(type Option)

type Inner = (c : Int)
type Outer = (b : Option Inner)

-- Source family: Kotlin safe-call issue family
-- Spec: §7.1.1.2
flattened : Option Outer -> Option Int
let flattened a = a?.b?.c

--! assertNoErrors
--! assertType flattened Option Outer -> Option Int
