module main

import std.prelude.(type Option, ctor Some, ctor None)

-- Source family: Kotlin Elvis issue family
-- Spec: §7.1.2
fallback : Option Int -> Int
let fallback x = x ?: 42

fromNone : Int
let fromNone = None ?: 42

fromSome : Int
let fromSome = Some 7 ?: 42

--! assertNoErrors
