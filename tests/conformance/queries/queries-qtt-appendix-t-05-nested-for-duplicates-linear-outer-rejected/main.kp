module main

data Token : Type =
    Token

consumeToken : (1 t : Token) -> Int
let consumeToken t =
    match t
    case Token -> 1

keyOfToken : (& t : Token) -> Int
let keyOfToken t = 0

bad : (1 xs : QueryCore (QueryMode.QueryMode QueryUse.OneShot QueryCard.QZeroOrMore) 1 Token) -> (ys : List Int) -> OnceQuery Int
let bad xs ys =
    OnceQuery [
        for t in xs
        for y in ys
        yield consumeToken t + y
    ]

--! assertErrorCount 1
--! assertDiagnosticMatch [Nn]ested|for|[Ll]inear|[Dd]uplicat|[Dd]rop|zero|many
