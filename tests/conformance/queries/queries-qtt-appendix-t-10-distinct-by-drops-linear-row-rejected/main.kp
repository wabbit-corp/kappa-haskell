module main

data Token : Type =
    Token

consumeToken : (1 t : Token) -> Int
let consumeToken t =
    match t
    case Token -> 1

keyOfToken : (& t : Token) -> Int
let keyOfToken t = 0

bad : (1 xs : QueryCore (QueryMode.QueryMode QueryUse.OneShot QueryCard.QZeroOrMore) 1 Token) -> OnceQuery Int
let bad xs =
    OnceQuery [
        for t in xs
        distinct by 0
        yield consumeToken t
    ]

--! assertErrorCount 1
--! assertDiagnosticMatch distinct|[Dd]uplicate|[Dd]iscard|[Dd]rop|[Ll]inear
