module main

data Token : Type =
    Token

consumeToken : (1 t : Token) -> Int
let consumeToken t =
    match t
    case Token -> 1

keyOfToken : (& t : Token) -> Int
let keyOfToken t = 0

touches : (& c : Token) -> Int -> Bool
let touches c o = True

bad :
    (customers : QueryCore (QueryMode.QueryMode QueryUse.Reusable QueryCard.QZeroOrMore) 1 Token) ->
    (orders : List Int) ->
    QueryCore (QueryMode.QueryMode QueryUse.Reusable QueryCard.QZeroOrMore) 1 Token
let bad customers orders =
    QueryCore (QueryMode.QueryMode QueryUse.Reusable QueryCard.QZeroOrMore) 1 [
        for c in customers
        left join o in orders on touches c o into matchingOrders
        yield c
    ]

--! assertErrorCount 1
--! assertDiagnosticMatch left join|[Cc]apture|[Ll]inear|delayed
