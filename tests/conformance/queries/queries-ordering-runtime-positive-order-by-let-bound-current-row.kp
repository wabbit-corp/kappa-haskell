module main

type Row = (id : Int, value : Int)

rows : List Row
let rows =
    [
        (id = 2, value = 9),
        (id = 1, value = 3),
        (id = 1, value = 4)
    ]

ordered : List Int
let ordered =
    [
        for row in rows
        let sortKey = row.id
        order by sortKey
        yield row.value
    ]

result : Int
let result =
    match ordered
      case a :: b :: c :: Nil -> 100 * a + 10 * b + c
      case _ -> 0

--! assertNoErrors
--! assertType ordered List Int
--! assertType result Int
--! assertEval result 349
