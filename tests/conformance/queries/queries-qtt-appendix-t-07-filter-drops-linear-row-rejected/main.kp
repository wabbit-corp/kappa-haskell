module main

data Token : Type =
    Token

consumeToken : (1 t : Token) -> Int
let consumeToken t =
    match t
    case Token -> 1

keyOfToken : (& t : Token) -> Int
let keyOfToken t = 0

bad : Bool -> (1 xs : QueryCore (QueryMode.QueryMode QueryUse.OneShot QueryCard.QZeroOrMore) 1 Token) -> OnceQuery Int
let bad flag xs =
    OnceQuery [
        for t in xs
        if flag
        yield consumeToken t
    ]

--! assertErrorCount 1
--! assertDiagnosticMatch if|[Ff]ilter|[Dd]iscard|[Dd]rop|[Ll]inear
