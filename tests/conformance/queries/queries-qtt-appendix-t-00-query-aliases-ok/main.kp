module main

single : Query Int
let single =
    Query [ yield 1 ]

onceSingle : OnceQuery Int
let onceSingle =
    OnceQuery [ yield 1 ]

explicitSingleton : QueryCore (QueryMode.QueryMode QueryUse.Reusable QueryCard.QOne) ω Int
let explicitSingleton =
    QueryCore (QueryMode.QueryMode QueryUse.Reusable QueryCard.QOne) ω [ yield 1 ]

