@PrivateByDefault module main

data Byte : Type =
    Byte

data Vec (n : Nat) (a : Type) : Type =
    VNil

makeVec : (n : Nat) -> Vec n Byte
let makeVec (n : Nat) : Vec n Byte = VNil


type Sized : Type = (len : Nat, buf : Vec this.len Byte)

makeSized : Nat -> Sized
let makeSized (n : Nat) : Sized =
    (buf = makeVec this.len, len = n)
