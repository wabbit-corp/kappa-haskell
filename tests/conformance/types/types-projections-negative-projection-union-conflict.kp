module main

--! allow_unsafe_consume

data Buffer : Type =
    Buffer

type Pair = (1 buf : Buffer)

consumeWhole : (1 p : Pair) -> Unit
let consumeWhole p =
    let _ = unsafeConsume p
    in ()

projection chooseBuf (place a : Pair) (place b : Pair) (which : Bool) : Buffer =
    if which then yield a.buf else yield b.buf

bad : (1 a : Pair) -> (1 b : Pair) -> Bool -> Unit
let bad a b which =
    let & p = chooseBuf a b which
    consumeWhole a

--! assertErrorCount 1
--! assertDiagnosticCodes E_QTT_BORROW_OVERLAP
