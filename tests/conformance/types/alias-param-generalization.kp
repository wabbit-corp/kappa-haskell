module main

-- §11.3.3: an unannotated alias parameter whose kind the body does not
-- constrain generalizes, so the alias applies to a value argument.
data A : Type =
    A

type Dep x = Nat

demo : (x : A) -> Dep x
let demo x =
    match x
    case A -> 0

-- recursive type aliases are not admitted (§15.16): data is required
type I1 = (left : I1)

salvaged : I1
let salvaged = ()

--! assertErrorCount 1
--! assertDiagnosticCodes E_RECURSIVE_TYPE_ALIAS
--! assertType demo (x : A) -> Dep x
