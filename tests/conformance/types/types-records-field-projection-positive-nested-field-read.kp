module main

type NestedRecord : Type = (subElement : Int)
type MyRecord : Type = (nested : NestedRecord)

getNestedSubElement : MyRecord -> Int
let getNestedSubElement rec = rec.nested.subElement

example : Int
let example = getNestedSubElement (nested = (subElement = 42))

-- Source issue: Idris2#50
