@PrivateByDefault module main

data Byte : Type =
    Byte

data Vec (n : Nat) (a : Type) : Type =
    VNil

makeVec : (n : Nat) -> Vec n Byte
let makeVec (n : Nat) : Vec n Byte = VNil


withBuffer : forall (r : RecRow). (len : Nat, buf : Vec this.len Byte | r) -> Nat
let withBuffer (@0 r : RecRow) (rec : (len : Nat, buf : Vec this.len Byte | r)) : Nat = rec.len
