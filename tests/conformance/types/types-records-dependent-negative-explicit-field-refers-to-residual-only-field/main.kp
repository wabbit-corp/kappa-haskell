@PrivateByDefault module main

data Byte : Type =
    Byte

data Vec (n : Nat) (a : Type) : Type =
    VNil

makeVec : (n : Nat) -> Vec n Byte
let makeVec (n : Nat) : Vec n Byte = VNil


bad : forall (r : RecRow). (buf : Vec this.len Byte | r) -> Unit
let bad (@0 r : RecRow) (rec : (buf : Vec this.len Byte | r)) : Unit = ()
