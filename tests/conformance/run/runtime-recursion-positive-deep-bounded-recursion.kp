module main

-- Regression: deep (but terminating) recursion must succeed. The interpreter
-- now runs evaluation on a large-stack worker thread so that legitimate deep
-- recursion does not overflow the default stack. Depth 8000 comfortably exceeds
-- the default thread stack budget but stays well under the recursion guard.
countdown : Int -> Int
let countdown n =
    match n
      case 0 -> 0
      case _ -> countdown (n - 1)

result : Int
let result = countdown 8000

--! mode check
--! assertNoErrors
--! assertType result Int
--! assertEval result 0
