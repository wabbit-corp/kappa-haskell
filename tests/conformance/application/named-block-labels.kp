module main

-- §16.1.7.2 named-argument blocks: missing, unknown, and duplicated
-- labels are each one malformed-block diagnostic.
scale : (value : Int) -> (factor : Int) -> Int
let scale value factor = value * factor

missing : Int
let missing = scale { value = 3 }

extra : Int
let extra = scale { value = 3, factor = 4, offset = 1 }

duplicate : Int
let duplicate = scale { value = 3, value = 4, factor = 2 }

ok : Int
let ok = scale { factor = 4, value = 3 }

--! assertErrorCount 3
--! assertEval ok 12
