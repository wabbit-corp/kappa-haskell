--! mode run
--! assertNoErrors
--! assertStdout "5/6\nTrue\n1\n7\n1/2\n-2/3\n"

-- §28.2 Rational: exact ratio arithmetic. Add/Mul/Negatable/CheckedSub/
-- CheckedDiv via the operation traits, FieldLike via the algebraic
-- tower, FromInteger and FromFloat (exact dyadic decode).

module main

half : Rational
let half = fromInteger 1 / fromInteger 2

third : Rational
let third = fromInteger 1 / fromInteger 3

useField : forall (a : Type). (@_ : FieldLike a) -> a -> a -> a
let useField x y = add x y

main : UIO Unit
let main = do
    println (half + third)
    println (half == half)
    println (multiply half (fromInteger 2))
    println (useField (fromInteger 3) (fromInteger 4))
    println (fromFloat 0.5)
    println (negate (fromInteger 2 / fromInteger 3))
