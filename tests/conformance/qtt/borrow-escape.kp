--! assertErrorCount 1
--! assertDiagnosticCodes E_QTT_BORROW_ESCAPE
-- §3.1.1A (line 602-603): a borrow/ownership diagnostic MUST include the
-- borrow introduction site and the failing escape site.
--! assertDiagnosticRelated error kappa.borrow.escape borrow-start
--! assertDiagnosticRelated error kappa.borrow.escape borrow-escape-site

-- §12.3.2: a closure capturing an anonymous borrow may not escape
-- through the result.
module main

data Box : Type =
    Box Int

read : (& b : Box) -> Int
let read b = 0

bad : (& b : Box) -> (Unit -> Int)
let bad b = \_ -> read b
