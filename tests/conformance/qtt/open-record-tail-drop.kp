--! mode check
--! assertErrorCount 1
--! assertDiagnosticCodes E_ROW_TAIL_QUANTITY_UNSATISFIED

-- §13.2.7: a consuming (quantity-1) receiver of an open record type owns
-- its abstract residual tail. Forgetting that tail — reading only an
-- explicit prefix field and returning a value that does not carry the
-- tail — is unsound without a 'RecTailSatisfies r 0' premise (which v1
-- cannot express), because the tail may hold a linear resource. §3.2.4
-- mandates the dedicated kappa.row.tail-quantity family and its portable
-- alias E_ROW_TAIL_QUANTITY_UNSATISFIED for this row-tail quantity
-- demand (Spec.md:955-957, 3097-3128).
module main

forgetExtras :
    forall (r : RecRow).
    (1 rec : (name : String | r)) ->
    String
let forgetExtras (@0 r : RecRow) (rec : (name : String | r)) : String =
    rec.name
