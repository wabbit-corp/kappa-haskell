module main

-- Source issue: scala3#1857
-- Spec: §12.2.1, §12.3, §7.3.3
trait Builder a =
    Out : Type
    build : a -> Out

instance Builder Int =
    let Out = String
    let build x = primitiveIntToString x

buildViaImplicit : (@builder : Builder Int) -> builder.Out
let buildViaImplicit (@builder : Builder Int) = builder.build 42

buildViaSummon : String
let buildViaSummon =
    let
        dict = summon (Builder Int)
    in
        dict.build 7

implicitResult : String
let implicitResult = buildViaImplicit

--! assertNoErrors
--! assertType buildViaImplicit (@builder : Builder Int) -> builder.Out
--! assertType buildViaSummon String
--! assertType implicitResult String
--! assertEval buildViaSummon "7"
--! assertEval implicitResult "42"
