--! mode check
--! assertErrorCount 2
--! assertDiagnosticCodes E_TYPE_EQUALITY_MISMATCH, E_UNSOLVED_IMPLICIT

-- §3.1.11 single-cause cascade suppression at implicit-goal flush: one
-- ill-typed expression yields one diagnostic, not a cascade of two.
--
-- `bad1`: a non-numeric operand (`f`, a function) at `*` produces a type
-- mismatch (the operand does not fit the numeric domain). The postponed
-- `Mul ((x : Int) -> Int)` goal is the downstream consequence of that same
-- concrete-carrier rejection, so it is suppressed — one diagnostic total.
--
-- `bad2`: an overloaded value-position member (`empty`, needing `Monoid`)
-- whose carrier never gets solved leaves exactly one unsolved-implicit
-- diagnostic; the downstream same-span carrier mismatch is suppressed.
module main

f : (x : Int) -> Int
let f (x : Int) : Int = x

bad1 : Int
let bad1 = f * 2

bad2 : forall (m : Type). m
let bad2 = empty
