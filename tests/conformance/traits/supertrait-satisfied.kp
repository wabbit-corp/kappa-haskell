--! assertNoErrors

-- §14.1.4: supertrait premises are satisfied by a global instance
-- (ground head) or by the instance's own premises (premise instance).

trait MyEq (a : Type) =
    myEq : a -> a -> Bool

trait MyEq a => MyOrd (a : Type) =
    myLt : a -> a -> Bool

instance MyEq Integer =
    let myEq x y = eqInt x y

instance MyOrd Integer =
    let myLt x y = ltInt x y

data Box (a : Type) : Type =
    Box a

instance MyEq a => MyEq (Box a) =
    let myEq x y = True

instance MyEq a => MyOrd (Box a) =
    let myLt x y = False
