--! assertDiagnostic error E_TRAIT_SUPERTRAIT_UNSATISFIED

-- §14.1.4: an instance of a trait with a supertrait premise requires
-- evidence for the supertrait at the instance head.

trait MyEq (a : Type) =
    myEq : a -> a -> Bool

trait MyEq a => MyOrd (a : Type) =
    myLt : a -> a -> Bool

instance MyOrd Integer = --!! E_TRAIT_SUPERTRAIT_UNSATISFIED
    let myLt x y = ltInt x y
