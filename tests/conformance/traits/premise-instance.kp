--! mode run
--! assertNoErrors
--! assertStdout "True\nFalse\nTrue\n"

-- §14.3: an instance with a premise (Eq a => Eq (Stack a)) resolves the
-- premise dictionary, including recursively for nested element types.
-- (List/Option/Result Eq now ship in the prelude, so this uses a user type
-- to keep exercising user-declared premise instances.)

data Stack (a : Type) : Type =
    Empty
    Push a (Stack a)

instance Eq a => Eq (Stack a) =
    let (==) xs ys =
        match (xs, ys)
        case (Empty, Empty) -> True
        case (Push x xr, Push y yr) -> if x == y then xr == yr else False
        case _ -> False

main : UIO Unit
let main = do
    printlnString (show (Push 1 (Push 2 Empty) == Push 1 (Push 2 Empty)))
    printlnString (show (Push 1 Empty == Push 2 Empty))
    printlnString (show ((Push (Push 1 Empty) Empty) == (Push (Push 1 Empty) Empty)))
