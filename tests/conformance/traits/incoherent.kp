--! assertDiagnostic error E_INSTANCE_INCOHERENT
-- §3.1.1A: a trait-coherence diagnostic MUST include every surviving
-- incoherent instance declaration site.
--! assertDiagnosticRelated error E_INSTANCE_INCOHERENT instance-declaration-site

trait Label (a : Type) =
    label : a -> String

instance Label Integer =
    let label n = "first"

instance Label Integer =
    let label n = "second"

use : String
let use = label 5 --!! E_INSTANCE_INCOHERENT
