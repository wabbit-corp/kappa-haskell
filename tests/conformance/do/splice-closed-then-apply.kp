--! mode run
--! assertNoErrors
--! assertStdout "100\n"

-- §18.3.1: to splice a computation that yields a function and then apply
-- the resulting function, write `(!f) x`. The explicitly parenthesised
-- (closed) splice runs `getAdder` first and applies the resulting
-- function to `100`; it does NOT fold `100` into the splice operand.
getAdder : UIO (Int -> Int)
let getAdder = ioPure (\n -> n)

main : UIO Unit
let main = do
    let z = (!getAdder) 100
    printlnString (showInt z)
