--! assertNoErrors
--! assertExecute main 42

-- §7.4.1 / §8.2.2A: when the else-branch of a statement-if completes
-- abruptly (here: return), the condition's constructor test refines
-- its subject for the rest of the do-scope, so payload.value is
-- admissible after the guard. Also exercises the assertExecute
-- compatibility directive (run an IO entrypoint, compare the result).
module main

data Payload : Type =
    Box (value : Int)
    Empty

afterGuard : Payload -> IO Int
let afterGuard payload = do
    if payload is Box then pure () else do
        return 0

    pure (payload.value + 1)

main : IO Int
let main = afterGuard (Box 41)
