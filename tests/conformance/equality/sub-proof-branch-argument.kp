-- Checked subtraction evidence may be discharged from a branch fact after
-- transparent normalization through already-reducible instance members.
--! assertNoErrors
--! assertNoWarnings

instance CheckedSub Nat =
    let subDefined x y = leInt (natToInt y) (natToInt x)
    let subtractUnchecked x y = natOfInt (subInt (natToInt x) (natToInt y))

consume : Nat -> Nat
let consume n = n

branchArg : Nat -> Nat -> Nat
let branchArg x y =
    if leInt (natToInt y) (natToInt x)
    then consume (x - y)
    else 0
