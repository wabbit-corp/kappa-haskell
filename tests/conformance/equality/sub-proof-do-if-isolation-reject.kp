-- §16.4.2: the then-suite condition fact must NOT leak past the `if` into
-- the rest of the do-scope (the then-branch here is not abrupt, so no
-- postdominating refinement applies); the trailing `x - y` is rejected.
--! assertDiagnostic error E_UNSOLVED_IMPLICIT

module main

instance CheckedSub Nat =
    let subDefined x y = leInt (natToInt y) (natToInt x)
    let subtractUnchecked x y = natOfInt (subInt (natToInt x) (natToInt y))

consume : Nat -> Nat
let consume n = n

doLeak : Nat -> Nat -> UIO Unit
let doLeak x y = do
    if leInt (natToInt y) (natToInt x) then
        printlnString "ok"
    let d = consume (x - y) --!! E_UNSOLVED_IMPLICIT
    printlnString "after"
