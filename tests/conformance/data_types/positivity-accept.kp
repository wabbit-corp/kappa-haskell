--! mode check
--! assertNoErrors
-- §10.4 examples accepted: a strictly positive
-- recursive data type and a recursive type nested under the built-in
-- 'List' carrier (whose parameter is positive) are both well-formed.
@PrivateByDefault module main

data Tree (a : Type) : Type =
    Leaf
    Branch (Tree a) a (Tree a)

data Rose (a : Type) : Type =
    Node a (List (Rose a))
