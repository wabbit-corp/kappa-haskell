--! mode check
--! assertDiagnostic error E_DATA_NOT_STRICTLY_POSITIVE
-- §10.4 examples rejected: 'Rose' occurs inside the
-- domain of a function type ('Rose a -> a' is the argument of the
-- outer arrow), a negative occurrence, so the declaration MUST be
-- rejected.
@PrivateByDefault module main

data Rose (a : Type) : Type =
    Node a ((Rose a -> a) -> Rose a)
