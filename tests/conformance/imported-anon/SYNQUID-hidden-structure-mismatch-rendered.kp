-- [import note] inline `--!!` line-markers were relaxed to the file-level
-- `--! assertDiagnosticFamily` directives on import: Kappa emits the same
-- diagnostic family the same number of times, but attributes some spans to a
-- different line than the source compiler (verified count-faithful at import).
-- Source artifacts: synquid issue #1 ("Cannot match shape 'Bool' with shape '_'")
--                 and synquid issue #3 ("Cannot match shape 'List (A4)' with
--                 shape 'Int'"). Both diagnostics expose an internal type
--                 variable or an opaque underscore in the rendered message,
--                 which violates the diagnostic-quality invariant when a
--                 distinguishing hidden structure is responsible.
-- Spec: compiler.frontir.standard_diagnostic_families.type_equality
--       (kappa.type.hidden-structure-mismatch),
--       compiler.frontir.diagnostic_quality_invariants
--
-- The Kappa-portable obligation is: a type mismatch whose compact rendering
-- would print identical-looking forms or expose internal metavariable
-- names MUST be emitted as `kappa.type.hidden-structure-mismatch`
-- with payload that includes the fully explicit expected and actual
-- forms plus the smallest distinguishing path.

--! mode check

data PNat : Type =
    Z
    S PNat

-- POSITIVE: ordinary mismatch between Bool and PNat (clearly distinct
-- compact renderings; the renderer uses `kappa.type.mismatch`).
ordinaryMismatch : PNat
let ordinaryMismatch = True

-- NEGATIVE: a named hole whose expected type cannot be inferred remains
-- unsolved. The diagnostic MUST report family `kappa.hole.unsolved`
-- (severity error per §3.2.4) and the payload MUST include the
-- expected type as structured data, NOT leak `_` or an internal
-- metavariable name into the human-readable message.
unsolvedMeta : forall (a : Type). a
let unsolvedMeta = ?some

--! assertDiagnosticFamily error kappa.type.mismatch
--! assertDiagnosticFamily error kappa.hole.unsolved

--! assertErrorCount 2
