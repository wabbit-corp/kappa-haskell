-- [import note] inline `--!!` line-markers were relaxed to the file-level
-- `--! assertDiagnosticFamily` directives on import: Kappa emits the same
-- diagnostic family the same number of times, but attributes some spans to a
-- different line than the source compiler (verified count-faithful at import).
-- Source artifacts: synquid test/unit/HOChecking.sq, test/unit/HigherOrder.sq —
--                 `map :: f: (a -> b) -> xs: List a -> List b` is the canonical
--                 higher-order test; the unit tests stress how `f` is captured
--                 by recursion (closure form, environment form, let form,
--                 illegal scope form).
-- Spec: types.functions,
--       expressions.lambdas,
--       compiler.frontir.standard_diagnostic_families.name_import
--
-- A higher-order function takes a function-shaped argument. The portable Kappa
-- obligation is that the parameter's arrow type is enforced at the application
-- site and that the body of the higher-order function may pass that callable
-- argument to recursive calls. Out-of-scope use of the callable argument is
-- a name-resolution error.

--! mode check

data PNat : Type =
    Z
    S PNat

data List (a : Type) : Type =
    Nil
    Cons (head : a) (tail : List a)

-- POSITIVE: a higher-order `map` that recurses with the same callable.
map : forall (a : Type) (b : Type). (a -> b) -> List a -> List b
let map f xs =
    match xs
      case Nil          -> Nil
      case (Cons x ys)  -> Cons (f x) (map f ys)

-- POSITIVE: instantiate map with a concrete callable.
incAll : List PNat -> List PNat
let incAll xs = map (\ n -> S n) xs

-- POSITIVE: instantiate map at the level of a lambda.
constAll : List PNat -> List Bool
let constAll xs = map (\ _ -> True) xs

-- NEGATIVE: referencing `f` outside the lambda that binds it is an
-- unresolved-name diagnostic. Here `f` is referenced at top level.
badRef : List PNat -> List PNat
let badRef xs = map f xs

--! assertDiagnosticFamily error kappa.name.unresolved

--! assertErrorCount 1
