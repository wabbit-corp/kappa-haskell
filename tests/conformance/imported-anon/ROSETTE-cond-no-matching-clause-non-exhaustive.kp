-- [import note] inline `--!!` line-markers were relaxed to the file-level
-- `--! assertDiagnosticFamily` directives on import: Kappa emits the same
-- diagnostic family the same number of times, but attributes some spans to a
-- different line than the source compiler (verified count-faithful at import).
-- Source issue: ROSETTE-181 (4-queen example — cond with no matching
--                clause silently returns void in Rosette),
--                ROSETTE-83 (cond `=>` missing — incomplete cond
--                semantics)
-- Spec: expressions.match,
--       compiler.frontir.standard_diagnostic_families.pattern_exhaustiveness_reachability
--
-- The Rosette report relies on `cond` returning a useful value when
-- every test is false. Kappa requires either a wildcard arm (`_`) or
-- a proof that every possible scrutinee value is covered. Omitting
-- the wildcard for an open type like Int is a non-exhaustive match.

--! mode check

-- POSITIVE: cond-equivalent match has an explicit wildcard.
sign : Int -> Int
let sign n =
    match n
    case _ -> if n > 0 then 1 else if n < 0 then 0 - 1 else 0

-- POSITIVE: a finite enumeration is fully covered without wildcard.
data Color : Type =
    Red
    Green
    Blue

isPrimary : Color -> Bool
let isPrimary c =
    match c
    case Red   -> True
    case Green -> True
    case Blue  -> True

-- NEGATIVE: integer match without wildcard arm.
classify : Int -> Int
let classify n =
    match n
    case 0 -> 100
    case 1 -> 200

-- NEGATIVE: enumeration match missing one constructor.
firstTwo : Color -> Bool
let firstTwo c =
    match c
    case Red   -> True
    case Green -> True

--! assertDiagnosticFamily error kappa.pattern.non-exhaustive

--! assertErrorCount 2
