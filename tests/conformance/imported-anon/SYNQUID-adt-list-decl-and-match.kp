-- [import note] inline `--!!` line-markers were relaxed to the file-level
-- `--! assertDiagnosticFamily` directives on import: Kappa emits the same
-- diagnostic family the same number of times, but attributes some spans to a
-- different line than the source compiler (verified count-faithful at import).
-- Source artifacts: synquid test/checking/List-Append-Bad.sq, test/pldi16/List-Append.sq,
--                 test/comcom/List-Replicate.sq.
-- Spec: data_types.data_declarations,
--       expressions.match,
--       expressions.match.exhaustiveness_indexed_types_gadts
--
-- Synquid's canonical worked example is the polymorphic List a with Nil and Cons.
-- The Kappa-portable obligation is that a parametric ADT may be declared with two
-- constructors, then eliminated by an exhaustive match. Both arms must be reached
-- in their respective constructor branches.

--! mode check

-- POSITIVE: a parametric data declaration with two constructors.
data List (a : Type) : Type =
    Nil
    Cons (head : a) (tail : List a)

-- A small Peano natural so we do not depend on the elaboration of numeric
-- literals or on a prelude that may not be in scope under `mode analyze`.
data PNat : Type =
    Z
    S PNat

-- POSITIVE: a pattern match that covers both constructors.
isEmpty : forall (a : Type). List a -> Bool
let isEmpty xs =
    match xs
      case Nil        -> True
      case (Cons _ _) -> False

-- POSITIVE: a constructor application that uses positional arguments.
oneTwo : List PNat
let oneTwo = Cons (S Z) (Cons (S (S Z)) Nil)

-- POSITIVE: a recursive function over the same ADT.
length : forall (a : Type). List a -> PNat
let length xs =
    match xs
      case Nil         -> Z
      case (Cons _ ys) -> S (length ys)

-- NEGATIVE: a match that omits the Cons arm is non-exhaustive.
badIsEmpty : forall (a : Type). List a -> Bool
let badIsEmpty xs =
    match xs
      case Nil -> True

--! assertDiagnosticFamily error kappa.pattern.non-exhaustive

--! assertErrorCount 1
