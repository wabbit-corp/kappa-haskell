@PrivateByDefault module main


data Env : Type =
    Env (bias : Int)

addBias : (@ω env : Env) -> Int -> Int
let addBias (@ω env : Env) (x : Int) : Int =
    match env
    case Env bias -> x + bias

ok : Int
let ok : Int =
    block
        let (@ω env : Env) = Env 1
        block
            let (@ω env : Env) = Env 20
            addBias 2
