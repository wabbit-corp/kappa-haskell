module delve.generation_test

import delve.core.*
import delve.natutil.*
import delve.gen as gen
import delve.fixture as fixture

testStartsWithPetAndStarSign : Bool
let testStartsWithPetAndStarSign =
    let game = gen.newLevel fixture.testPack 0 1 (Size 80 24) 12345
    in listLength game.level.actors >= 2

testRumorsSeeded : Bool
let testRumorsSeeded =
    let game = gen.newLevel fixture.testPack 0 1 (Size 80 24) 12345
    in listLength game.rumors > 0
