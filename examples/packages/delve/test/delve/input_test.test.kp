module delve.input_test

import delve.core.*
import delve.natutil.*
import delve.input as input

testMovementKeys : Bool
let testMovementKeys =
    input.keyToCommand (KeyChar "a") == Move West &&
    input.keyToCommand (KeyChar "d") == Move East &&
    input.keyToCommand (KeyChar "w") == Move North &&
    input.keyToCommand (KeyChar "x") == Move South &&
    input.keyToCommand (KeyChar "s") == Rest

testFeatureKeys : Bool
let testFeatureKeys =
    input.keyToCommand (KeyChar "p") == Pray &&
    input.keyToCommand (KeyChar "r") == Engrave &&
    input.keyToCommand (KeyChar "v") == CycleTactic &&
    input.keyToCommand (KeyChar "A") == TargetedAttack &&
    input.keyToCommand (KeyChar ";") == Look &&
    input.keyToCommand (KeyChar "m") == ToggleAudio

testMenuKeys : Bool
let testMenuKeys =
    input.menuKeyToCommand (KeyChar "n") == StartNewGame &&
    input.menuKeyToCommand (KeyChar "c") == LoadGame &&
    input.menuKeyToCommand (KeyChar "l") == LoadGame &&
    input.menuKeyToCommand (KeyChar "m") == ToggleAudio
