data Room : Type =
    Room
        (x : Int)
        (y : Int)
        (w : Int)
        (h : Int)

roomCenter : Room -> Vec2
let roomCenter r =
    Vec2 (r.x + (r.w / 2)) (r.y + (r.h / 2))

data Level : Type =
    Level
        (depth : Int)
        (size : Size)
        (tiles : Array Tile)
        (rooms : List Room)
        (actors : List Actor)
        (items : List GroundItem)
        (messages : List String)
        (turn : Nat)
        (branch : Int)

data PlayerState : Type =
    PlayerState
        (actorId : Int)
        (hunger : Int)
        (gold : Int)
        (identified : List ItemKind)
        (tactic : Tactic)
        (starSign : StarSign)
        (corruption : Int)
        (mutations : List Mutation)
        (favor : Int)
        (faith : Faith)
        (reputation : Int)

-- Data-driven content registry. These definitions are deliberately in core so
-- gameplay, save/load, and JSON decoding agree on one schema. String IDs are
-- authored content identities; enum fields are the typed compatibility bridge
-- used by the existing game rules. That is not hardcoding gameplay, it is a
-- schema contract. Truly dynamic IDs can be added by adding new component-only
-- systems without changing these compatibility constructors.
data ItemDef : Type =
    ItemDef
        (id : String)
        (kind : ItemKind)
        (displayName : String)
        (trueName : String)
        (glyph : String)
        (class : ItemClass)
        (stackable : Bool)
        (power : Int)
        (charges : Int)
        (startsIdentified : Bool)
        (beatitudeKnownByDefault : Bool)

data ItemAffix : Type =
    ItemAffix
        (id : String)
        (name : String)
        (class : ItemClass)
        (powerBonus : Int)
        (weight : Int)

data ActorDef : Type =
    ActorDef
        (id : String)
        (species : Species)
        (name : String)
        (glyph : String)
        (stats : Stats)
        (attitude : Attitude)
        (faction : Faction)
        (morale : Int)
        (loyalty : Int)
        (inventory : List ItemKind)
        (tags : List String)
        (abilities : List Ability)
        (description : String)

data SpawnRule : Type =
    SpawnRule
        (id : String)
        (minDepth : Int)
        (maxDepth : Int)
        (weight : Int)
        (branch : Int)

data BranchDef : Type =
    BranchDef
        (id : Int)
        (name : String)
        (entranceDepth : Int)
        (floors : Int)
        (boss : Species)

data TacticDef : Type =
    TacticDef
        (tactic : Tactic)
        (name : String)
        (attackBonus : Int)
        (damageBonus : Int)
        (defenseBonus : Int)
        (hungerCost : Int)
        (description : String)

data StarSignDef : Type =
    StarSignDef
        (sign : StarSign)
        (name : String)
        (description : String)
        (hpBonus : Int)
        (mpBonus : Int)
        (strBonus : Int)
        (dexBonus : Int)
        (defBonus : Int)
        (hungerBonus : Int)
        (corruptionResistance : Int)

data MutationDef : Type =
    MutationDef
        (mutation : Mutation)
        (name : String)
        (hpBonus : Int)
        (mpBonus : Int)
        (strBonus : Int)
        (dexBonus : Int)
        (defBonus : Int)
        (hungerTax : Int)
        (description : String)

data FaithDef : Type =
    FaithDef
        (faith : Faith)
        (name : String)
        (alignment : String)

data WorldGenConfig : Type =
    WorldGenConfig
        (mapMinWidth : Int)
        (mapMaxWidth : Int)
        (mapMinHeight : Int)
        (mapMaxHeight : Int)
        (minRoomSize : Int)
        (maxRoomSize : Int)
        (roomAttempts : Int)
        (baseMonsterChance : Int)
        (monsterChancePerDepth : Int)
        (itemChance : Int)
        (altarChance : Int)
        (loreStoneChance : Int)
        (trapBaseChance : Int)
        (trapChancePerDepth : Int)
        (chaosVentBaseChance : Int)
        (chaosVentChancePerDepth : Int)
        (chaosVentSpreadChance : Int)

data SaveConfig : Type =
    SaveConfig
        (directory : String)
        (path : String)
        (formatVersion : Int)
        (autosaveOnQuit : Bool)

data RulesConfig : Type =
    RulesConfig
        (startingHunger : Int)
        (messageLimit : Nat)

data ContentPack : Type =
    ContentPack
        (packId : String)
        (version : String)
        (rules : RulesConfig)
        (worldgen : WorldGenConfig)
        (save : SaveConfig)
        (items : List ItemDef)
        (actors : List ActorDef)
        (monsterSpawns : List SpawnRule)
        (itemSpawns : List SpawnRule)
        (tactics : List TacticDef)
        (starSigns : List StarSignDef)
        (mutations : List MutationDef)
        (faiths : List FaithDef)
        (rumors : List Rumor)
        (affixes : List ItemAffix)
        (branches : List BranchDef)

-- ECS-ish runtime mirror. The old Actor/Item lists remain the authoritative
-- gameplay representation for this pass so no feature is lost; the ECS world is
-- a normalized projection used by config, save files, and future systems.
data Component : Type =
    PositionC (pos : Vec2)
    RenderC (glyph : String)
    StatsC (stats : Stats)
    ActorC (actor : Actor)
    ItemC (item : Item)
    InventoryC (items : List Item)
    AIStateC (attitude : Attitude) (faction : Faction)
    TagsC (tags : List String)

data Entity : Type =
    Entity
        (id : Int)
        (blueprintId : String)
        (components : List Component)

data EcsWorld : Type =
    EcsWorld
        (nextId : Int)
        (entities : List Entity)

emptyEcsWorld : EcsWorld
let emptyEcsWorld = EcsWorld 1 Nil


data GameMode : Type =
    MainMenu
    Playing
    InventoryMode
    HelpMode
    CharacterMode
    CharacterCreation
    LookMode
    Dead
    Won
    Quit

data GameState : Type =
    GameState
        (rng : Nat)
        (player : PlayerState)
        (level : Level)
        (mode : GameMode)
        (lastCommand : String)
        (rumors : List Rumor)
        (content : ContentPack)
        (ecs : EcsWorld)
        (savePath : String)
        (audioMuted : Bool)
        (levels : List Level)
        (invCursor : Int)
        (creationGod : Int)
        (lookPos : Vec2)

data Command : Type =
    StartNewGame
    LoadGame
    Move (dir : Direction)
    Rest
    Open
    Close
    ToggleDoor
    PickUp
    DropFirst
    Inventory
    UseFirst
    ZapFirst
    ThrowFirst
    Descend
    Ascend
    Look
    Help
    Character
    Pray
    Engrave
    Talk
    CycleTactic
    TargetedAttack
    ToggleAudio
    SaveAndQuit
    QuitNoSave
    SelectUp
    SelectDown
    UseSelected
    DropSelected
    ThrowSelected
    ZapSelected
    GodPrev
    GodNext
    RerollSign
    ConfirmCreation
    NoCommand

data Key : Type =
    KeyChar (text : String)
    KeyEscape
    KeyEnter
    KeyBackspace
    KeyArrow (dir : Direction)
    KeyResize
    KeyUnknown

directionCode : Direction -> Int
let directionCode d =
    match d
    case North -> 0
    case South -> 1
    case West -> 2
    case East -> 3
    case NorthWest -> 4
    case NorthEast -> 5
    case SouthWest -> 6
    case SouthEast -> 7
    case Wait -> 8

instance Eq Direction =
    let (==) a b = directionCode a == directionCode b

tileKindCode : TileKind -> Int
let tileKindCode k =
    match k
    case VoidTile -> 0
    case Floor -> 1
    case Wall -> 2
    case ClosedDoor -> 3
    case OpenDoor -> 4
    case Upstairs -> 5
    case Downstairs -> 6
    case Water -> 7
    case Lava -> 8
    case Trap -> 9
    case Altar -> 10
    case LoreStone -> 11
    case ChaosVent -> 12
    case BranchDown -> 13

instance Eq TileKind =
    let (==) a b = tileKindCode a == tileKindCode b

beatitudeCode : Beatitude -> Int
let beatitudeCode b =
    match b
    case Blessed -> 0
    case Uncursed -> 1
    case Cursed -> 2
    case UnknownBeatitude -> 3

instance Eq Beatitude =
    let (==) a b = beatitudeCode a == beatitudeCode b

itemClassCode : ItemClass -> Int
let itemClassCode c =
    match c
    case CoinClass -> 0
    case PotionClass -> 1
    case ScrollClass -> 2
    case FoodClass -> 3
    case WeaponClass -> 4
    case ArmorClass -> 5
    case WandClass -> 6
    case ToolClass -> 7
    case CorpseClass -> 8
    case ArtifactClass -> 9

instance Eq ItemClass =
    let (==) a b = itemClassCode a == itemClassCode b

itemKindCode : ItemKind -> Int
let itemKindCode k =
    match k
    case Gold -> 0
    case PotionHealing -> 1
    case PotionMutation -> 2
    case PotionWater -> 3
    case ScrollIdentify -> 4
    case ScrollMapping -> 5
    case ScrollWard -> 6
    case FoodRation -> 7
    case Dagger -> 8
    case Sword -> 9
    case Mace -> 10
    case LeatherArmor -> 11
    case ChainMail -> 12
    case WandFire -> 13
    case WandDigging -> 14
    case WandPolymorph -> 15
    case HolySymbol -> 16
    case Corpse -> 17
    case ChaosShard -> 18
    case Amulet -> 19

instance Eq ItemKind =
    let (==) a b = itemKindCode a == itemKindCode b

speciesCode : Species -> Int
let speciesCode s =
    match s
    case PlayerSpecies -> 0
    case Hound -> 1
    case Goblin -> 2
    case Orc -> 3
    case Kobold -> 4
    case Rat -> 5
    case Bat -> 6
    case Troll -> 7
    case Skeleton -> 8
    case Wizard -> 9
    case Dragon -> 10
    case ChaosSpawn -> 11
    case Pilgrim -> 12

instance Eq Species =
    let (==) a b = speciesCode a == speciesCode b

factionCode : Faction -> Int
let factionCode f =
    match f
    case HeroFaction -> 0
    case BeastFaction -> 1
    case CaveFaction -> 2
    case UndeadFaction -> 3
    case ChaosFaction -> 4
    case NeutralFaction -> 5

instance Eq Faction =
    let (==) a b = factionCode a == factionCode b

attitudeCode : Attitude -> Int
let attitudeCode a =
    match a
    case PlayerControlled -> 0
    case Friendly -> 1
    case Neutral -> 2
    case Hostile -> 3
    case Sleeping -> 4
    case Fleeing -> 5

instance Eq Attitude =
    let (==) a b = attitudeCode a == attitudeCode b

bodyPartCode : BodyPart -> Int
let bodyPartCode p =
    match p
    case Head -> 0
    case Torso -> 1
    case LeftArm -> 2
    case RightArm -> 3
    case LeftLeg -> 4
    case RightLeg -> 5

instance Eq BodyPart =
    let (==) a b = bodyPartCode a == bodyPartCode b

tacticCode : Tactic -> Int
let tacticCode t =
    match t
    case Coward -> 0
    case Defensive -> 1
    case Balanced -> 2
    case Aggressive -> 3
    case Berserk -> 4

instance Eq Tactic =
    let (==) a b = tacticCode a == tacticCode b

starSignCode : StarSign -> Int
let starSignCode s =
    match s
    case Raven -> 0
    case Book -> 1
    case Wand -> 2
    case Unicorn -> 3
    case Salamander -> 4
    case DragonSign -> 5
    case SwordSign -> 6
    case Falcon -> 7
    case Cup -> 8
    case Candle -> 9
    case Wolf -> 10
    case Tree -> 11

instance Eq StarSign =
    let (==) a b = starSignCode a == starSignCode b

mutationCode : Mutation -> Int
let mutationCode m =
    match m
    case Claws -> 0
    case NightEyes -> 1
    case StoneSkin -> 2
    case HollowBones -> 3
    case PoisonTouch -> 4
    case Ravenous -> 5
    case BurningBlood -> 6
    case WhisperingSkull -> 7

instance Eq Mutation =
    let (==) a b = mutationCode a == mutationCode b

faithCode : Faith -> Int
let faithCode f =
    match f
    case EmberMother -> 0
    case RootFather -> 1
    case VeiledWitness -> 2

instance Eq Faith =
    let (==) a b = faithCode a == faithCode b

gameModeCode : GameMode -> Int
let gameModeCode mode =
    match mode
    case MainMenu -> 0
    case Playing -> 1
    case InventoryMode -> 2
    case HelpMode -> 3
    case CharacterMode -> 4
    case Dead -> 5
    case Won -> 6
    case Quit -> 7
    case CharacterCreation -> 8
    case LookMode -> 9

instance Eq GameMode =
    let (==) a b = gameModeCode a == gameModeCode b

commandTag : Command -> Int
let commandTag c =
    match c
    case StartNewGame -> 0
    case LoadGame -> 1
    case Move _ -> 2
    case Rest -> 3
    case Open -> 4
    case Close -> 5
    case PickUp -> 6
    case DropFirst -> 7
    case Inventory -> 8
    case UseFirst -> 9
    case ZapFirst -> 10
    case ThrowFirst -> 11
    case Descend -> 12
    case Ascend -> 13
    case Look -> 14
    case Help -> 15
    case Character -> 16
    case Pray -> 17
    case Engrave -> 18
    case Talk -> 19
    case CycleTactic -> 20
    case TargetedAttack -> 21
    case ToggleAudio -> 22
    case SaveAndQuit -> 23
    case QuitNoSave -> 24
    case NoCommand -> 25
    case ToggleDoor -> 26
    case SelectUp -> 27
    case SelectDown -> 28
    case UseSelected -> 29
    case DropSelected -> 30
    case ThrowSelected -> 31
    case ZapSelected -> 32
    case GodPrev -> 33
    case GodNext -> 34
    case RerollSign -> 35
    case ConfirmCreation -> 36

instance Eq Command =
    let (==) a b =
        match (a, b)
        case (Move da, Move db) -> da == db
        case _ -> commandTag a == commandTag b

instance Eq Key =
    let (==) a b =
        match (a, b)
        case (KeyChar x, KeyChar y) -> x == y
        case (KeyArrow dx, KeyArrow dy) -> dx == dy
        case (KeyEscape, KeyEscape) -> True
        case (KeyEnter, KeyEnter) -> True
        case (KeyBackspace, KeyBackspace) -> True
        case (KeyResize, KeyResize) -> True
        case (KeyUnknown, KeyUnknown) -> True
        case _ -> False

takeMessages : Nat -> List String -> List String
let takeMessages n xs decreases listLength xs =
    match xs
    case Nil -> Nil
    case h :: t -> if n <= 0 then Nil else h :: takeMessages (natOfInt (subInt (natToInt n) 1)) t

message : String -> GameState -> GameState
let message text game =
    let msgs = takeMessages game.content.rules.messageLimit ((::) text game.level.messages)
    let level2 = Level game.level.depth game.level.size game.level.tiles game.level.rooms game.level.actors game.level.items msgs game.level.turn game.level.branch
    in GameState game.rng game.player level2 game.mode game.lastCommand game.rumors game.content game.ecs game.savePath game.audioMuted game.levels game.invCursor game.creationGod game.lookPos

playerActor : GameState -> Option Actor
let playerActor game =
    findActor game.player.actorId game.level.actors

findActor : Int -> List Actor -> Option Actor
let findActor id actors decreases listLength actors =
    match actors
    case Nil -> None
    case a :: rest ->
        if a.id == id then Some a else findActor id rest

replaceActor : Actor -> List Actor -> List Actor
let replaceActor actor actors decreases listLength actors =
    match actors
    case Nil -> Nil
    case a :: rest ->
        if a.id == actor.id then (::) actor rest else (::) a (replaceActor actor rest)

removeDeadActors : List Actor -> List Actor
let removeDeadActors actors decreases listLength actors =
    match actors
    case Nil -> Nil
    case a :: rest ->
        if a.alive then (::) a (removeDeadActors rest) else removeDeadActors rest

-- Persistent-level store: visited levels are kept (keyed by depth for now;
-- branch identity is added when themed branches land) so stairs restore the
-- level you left rather than regenerating it.
sameLevelKey : Int -> Int -> Level -> Bool
let sameLevelKey branch depth lvl = lvl.branch == branch && lvl.depth == depth

storeLevel : Level -> List Level -> List Level
let storeLevel lvl levels decreases listLength levels =
    match levels
    case Nil -> [lvl]
    case h :: rest -> if sameLevelKey lvl.branch lvl.depth h then (::) lvl rest else (::) h (storeLevel lvl rest)

takeLevel : Int -> Int -> List Level -> Option (value : Level, rest : List Level)
let takeLevel branch depth levels decreases listLength levels =
    match levels
    case Nil -> None
    case h :: rest ->
        if sameLevelKey branch depth h then Some (value = h, rest = rest)
        else
            match takeLevel branch depth rest
            case None -> None
            case Some r -> Some (value = r.value, rest = (::) h r.rest)

actorAt : Vec2 -> List Actor -> Option Actor
let actorAt pos actors decreases listLength actors =
    match actors
    case Nil -> None
    case a :: rest ->
        if a.alive && eqPos a.pos pos then Some a else actorAt pos rest

hostileTo : Actor -> Actor -> Bool
let hostileTo a b =
    if a.faction == b.faction then False
    elif a.attitude == Friendly && b.faction == HeroFaction then False
    elif b.attitude == Friendly && a.faction == HeroFaction then False
    elif a.attitude == Hostile then True
    elif b.attitude == Hostile then True
    elif a.faction == ChaosFaction && b.faction != ChaosFaction then True
    elif b.faction == ChaosFaction && a.faction != ChaosFaction then True
    else False

isPlayerOrFriend : Actor -> Bool
let isPlayerOrFriend a =
    a.faction == HeroFaction

bytes : String -> Bytes
let bytes text = utf8Bytes text
