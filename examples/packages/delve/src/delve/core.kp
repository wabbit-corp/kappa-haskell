module delve.core

import std.unicode.(utf8Bytes)

-- Delve: native Linux terminal roguelike. Second pass: richer content,
-- interacting systems, and data-driven game definitions.

data GameError : Type =
    TerminalError (message : String)
    ConfigError (message : String)
    JsonError (message : String)
    FileError (message : String)
    SaveError (message : String)
    InvalidWorld (message : String)
    QuitRequested

data Vec2 : Type =
    Vec2 (x : Int) (y : Int)

data Size : Type =
    Size (width : Int) (height : Int)

data Direction : Type =
    North
    South
    West
    East
    NorthWest
    NorthEast
    SouthWest
    SouthEast
    Wait

moveDelta : Direction -> Vec2
let moveDelta dir =
    match dir
    case North -> Vec2 0 (-1)
    case South -> Vec2 0 1
    case West -> Vec2 (-1) 0
    case East -> Vec2 1 0
    case NorthWest -> Vec2 (-1) (-1)
    case NorthEast -> Vec2 1 (-1)
    case SouthWest -> Vec2 (-1) 1
    case SouthEast -> Vec2 1 1
    case Wait -> Vec2 0 0

addPos : Vec2 -> Vec2 -> Vec2
let addPos a b =
    Vec2 (a.x + b.x) (a.y + b.y)

eqPos : Vec2 -> Vec2 -> Bool
let eqPos a b =
    (a.x == b.x) && (a.y == b.y)

manhattan : Vec2 -> Vec2 -> Int
let manhattan a b =
    let dx = if a.x >= b.x then a.x - b.x else b.x - a.x
    let dy = if a.y >= b.y then a.y - b.y else b.y - a.y
    in dx + dy

chebyshev : Vec2 -> Vec2 -> Int
let chebyshev a b =
    let dx = if a.x >= b.x then a.x - b.x else b.x - a.x
    let dy = if a.y >= b.y then a.y - b.y else b.y - a.y
    in if dx >= dy then dx else dy

data TileKind : Type =
    VoidTile
    Floor
    Wall
    ClosedDoor
    OpenDoor
    Upstairs
    Downstairs
    Water
    Lava
    Trap
    Altar
    LoreStone
    ChaosVent
    BranchDown

-- `warded` is the tiny Delve version of NetHack's defensive engraving idea:
-- a temporary inscription that makes many monsters hesitate unless you attack.
data Tile : Type =
    Tile
        (kind : TileKind)
        (seen : Bool)
        (lit : Bool)
        (blood : Bool)
        (warded : Bool)

defaultTile : Tile
let defaultTile = Tile Wall False False False False

isTransparent : Tile -> Bool
let isTransparent t =
    match t.kind
    case Wall -> False
    case ClosedDoor -> False
    case VoidTile -> False
    case _ -> True

isWalkable : Tile -> Bool
let isWalkable t =
    match t.kind
    case Floor -> True
    case OpenDoor -> True
    case ClosedDoor -> False
    case Upstairs -> True
    case Downstairs -> True
    case Trap -> True
    case Water -> True
    case Lava -> True
    case Altar -> True
    case LoreStone -> True
    case ChaosVent -> True
    case BranchDown -> True
    case _ -> False

data Beatitude : Type =
    Blessed
    Uncursed
    Cursed
    UnknownBeatitude

data ItemClass : Type =
    CoinClass
    PotionClass
    ScrollClass
    FoodClass
    WeaponClass
    ArmorClass
    WandClass
    ToolClass
    CorpseClass
    ArtifactClass

data ItemKind : Type =
    Gold
    PotionHealing
