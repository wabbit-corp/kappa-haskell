-- Native backend conformance for §6.5/§29.5 byte / bytes / grapheme:
-- byte & grapheme literals (values), the std.bytes portable operations,
-- and the linear BytesBuilder.  Native output must match the interpreter
-- exactly.  (Byte/grapheme literal *patterns* are not in the surface
-- grammar, so equality is tested via eqByte, not match.)
module main

import std.bytes.*

bs : Bytes
let bs = bytesFromList (b'\x68' :: b'\x69' :: Nil)

built : Bytes
let built = finishBytesBuilder (bytesBuilderByte b'\x21' (bytesBuilderBytes bs newBytesBuilder))

classify : Byte -> String
let classify b = if eqByte b b'\x68' then "h" else "other"

main : UIO Unit
let main = do
    printlnString (showInt (natToInt (bytesLength bs)))     -- 2
    println (bytesIsEmpty emptyBytes)                        -- True
    println (bytesStartsWith (singletonByte b'\x68') bs)     -- True
    printlnString (showBytes built)                          -- 0x686921
    printlnString (showInt (natToInt (bytesLength built)))   -- 3
    println (bytesContains (singletonByte b'\x69') bs)       -- True
    println (bytesEndsWith (singletonByte b'\x69') bs)       -- True
    printlnString (showBytes (bytesDrop (natOfInt 1) bs))    -- 0x69
    printlnString (showByte b'\x41')                         -- b'\x41'
    printlnString (classify b'\x68')                         -- h
    printlnString (classify b'\x00')                         -- other
    printlnString (showGrapheme g'a')                        -- g'a'
