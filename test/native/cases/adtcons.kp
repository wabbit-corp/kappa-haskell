-- R1.1 / P0-A probe: saturated constructor application.
--
-- `n :: acc` is a saturated application of the eta-expanded `(::)` constructor.
-- It must lower to a DIRECT `kctor(KCT_CONS, …)` — not a 3-deep curried
-- `kclo`/`kapp`/`kappi` closure chain (the eta-ctor storm that dominated
-- listfold/adtbuild).  Because the cons no longer captures the env, the
-- builder's body is capture-free, re-enabling the QW2 in-place self-tail loop
-- (P0-B).  Output must match the interpreter exactly.
module main

range : Int -> List Int -> List Int
let range n acc = if leInt n 0 then acc else range (subInt n 1) (n :: acc)

foldSum : List Int -> Int -> Int
let foldSum xs acc =
  match xs
  case Nil -> acc
  case y :: rest -> foldSum rest (addInt acc y)

-- a non-list ADT too, to exercise a multi-field user constructor on the
-- construction path (not just the builtin `::`).
data Pair = MkPair Int Int

fst3 : Pair -> Int
let fst3 p = match p case MkPair a _ -> a

snd3 : Pair -> Int
let snd3 p = match p case MkPair _ b -> b

main : UIO Unit
let main = do
  printlnString (showInt (foldSum (range 10 Nil) 0))   -- 1+2+…+10 = 55
  let p = MkPair 3 4
  printlnString (showInt (addInt (fst3 p) (snd3 p)))   -- 7
