-- Native backend tail-call stress: a value-level tail-recursive function
-- driven to a depth (2,000,000) that would overflow the default ~8 MB C
-- stack if compiled as ordinary recursive C calls.  The native backend
-- compiles a tail-position self-call to a loop, so this runs in constant C
-- stack.  (The interpreter cannot reach this depth — it trips the §32.1
-- recursion-depth guard — so this case is native-only and checked by
-- result, not by interpreter equivalence.)
module main

-- sum 1..n with an accumulator; the else-branch call is in tail position.
sumTo : Int -> Int -> Int
let sumTo n acc = if leInt n 0 then acc else sumTo (subInt n 1) (addInt acc n)

-- a second tail-recursive shape (no accumulator arithmetic in the result).
countDown : Int -> Int
let countDown n = if leInt n 0 then 7 else countDown (subInt n 1)

main : UIO Unit
let main = do
    printlnString (showInt (sumTo 2000000 0))    -- 2000001000000
    printlnString (showInt (countDown 3000000))  -- 7
