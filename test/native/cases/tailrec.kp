-- Native backend tail-call stress (§27.5A.3 stack-safe lowering): tail
-- recursion driven to depths (millions) that would overflow the default
-- ~8 MB C stack as ordinary recursive C calls.  Direct self-calls loop in
-- the worker; mutual recursion and calls through a function value run via
-- the trampoline.  Native-only (the interpreter trips its §32.1 depth
-- guard at these depths), checked by result.
module main

sumTo : Int -> Int -> Int
let sumTo n acc = if leInt n 0 then acc else sumTo (subInt n 1) (addInt acc n)

countDown : Int -> Int
let countDown n = if leInt n 0 then 7 else countDown (subInt n 1)

-- mutual tail recursion (trampoline)
isEven : Int -> Bool
let isEven n = if eqInt n 0 then True else isOdd (subInt n 1)
isOdd : Int -> Bool
let isOdd n = if eqInt n 0 then False else isEven (subInt n 1)

-- tail call through a function value (trampoline)
applyTail : (Int -> Int) -> Int -> Int
let applyTail f n = if leInt n 0 then 0 else applyTail f (f n)
dec : Int -> Int
let dec n = subInt n 1

main : UIO Unit
let main = do
    printlnString (showInt (sumTo 2000000 0))      -- 2000001000000 (self-loop)
    printlnString (showInt (countDown 3000000))    -- 7 (self-loop)
    printlnString (if isEven 4000000 then "even" else "odd")  -- mutual
    printlnString (showInt (applyTail dec 3000000))           -- 0 (indirect)
