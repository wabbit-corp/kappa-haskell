-- Bench: listops
-- Purpose: a realistic small-list pipeline (map -> filter -> fold) — combines
--   constructor allocation (P0-A), pattern matching, KEnv binding (P1-H), and a
--   predicate in one workload, the way ordinary functional code mixes them.
-- Expected optimized lowering: direct kcons construction (R1.1), tag-switch /
--   decision-tree matches (R1.2 — integer tags already shipped; switch pending),
--   and (stretch goal beyond the roadmap) deforestation/fusion so the
--   intermediate lists are not materialized. At minimum: no eta-ctor closure
--   storm on the construction path.
-- Raw-C baseline idea: a single hand-fused loop over an array computing the
--   same sum (the deforested ideal), plus a linked-list variant that
--   materializes intermediates (like-for-like for the un-fused version).
-- Failure mode it detects: the compounded per-element cost of build+map+filter+
--   fold — the everyday case where several gaps stack up.
-- NOTE: map/filter are TAIL-recursive (accumulator; order is irrelevant to the
--   sum) so the pipeline runs at N=5e5 without deep non-tail C-stack recursion.
module main
range : Int -> List Int -> List Int
let range n acc = if leInt n 0 then acc else range (subInt n 1) (n :: acc)
mapDbl : List Int -> List Int -> List Int
let mapDbl xs acc = match xs case Nil -> acc case y :: rest -> mapDbl rest (mulInt y 2 :: acc)
keepEven : List Int -> List Int -> List Int
let keepEven xs acc =
    match xs
    case Nil -> acc
    case y :: rest -> if eqInt (modInt y 2) 0 then keepEven rest (y :: acc) else keepEven rest acc
foldSum : List Int -> Int -> Int
let foldSum xs acc = match xs case Nil -> acc case y :: rest -> foldSum rest (addInt acc y)
main : UIO Unit
let main = printlnString (showInt (foldSum (keepEven (mapDbl (range 500000 Nil) Nil) Nil) 0))
